{
  "name": "ai-diao-dian",
  "version": "1.0.0",
  "description": "AI钓点鱼情预测 - 拍照分析钓点鱼情",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --targets node18-win-x64 --output AI钓点鱼情预测.exe"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "uuid": "^10.0.0"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "uploads/**/*",
      ".env"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "."
  }
}
